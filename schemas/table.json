{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Schema for table schema definition files",
  "type": "object",
  "properties": {
    "table_name": {
      "type": "string"
    },
    "table_description": {
      "type": "string"
    },
    "reference": {
      "type": "string"
    },
    "columns": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "bool",
              "datetime",
              "decimal",
              "dynamic",
              "guid",
              "int",
              "long",
              "real",
              "string",
              "timespan"
            ]
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "type",
          "description"
        ]
      }
    }
  },
  "required": [
    "table_name",
    "table_description",
    "reference",
    "columns"
  ]
}